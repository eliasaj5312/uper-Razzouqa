<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>سوبر رزوقه - المغامرة الكاملة</title>
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background: #1a1a2e;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    overflow: hidden;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    user-select: none;
}

#gameWrapper {
    position: relative;
    border: 4px solid #ffd700;
    border-radius: 12px;
    box-shadow: 0 0 60px rgba(255, 215, 0, 0.3), 0 0 120px rgba(255, 215, 0, 0.1);
}

canvas {
    display: block;
    border-radius: 8px;
    background: #5c94fc;
    cursor: default;
}

#hud {
    position: absolute;
    top: 10px;
    left: 10px;
    right: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: white;
    font-size: 16px;
    font-weight: bold;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
    pointer-events: none;
    z-index: 10;
    padding: 0 8px;
}

.hud-item {
    background: rgba(0,0,0,0.6);
    padding: 6px 16px;
    border-radius: 20px;
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    gap: 8px;
}

.hud-item .icon {
    font-size: 20px;
}

.hud-item .value {
    color: #ffd700;
    font-size: 18px;
    min-width: 30px;
    text-align: center;
}

#livesDisplay .value { color: #ff6b6b; }
#coinsDisplay .value { color: #ffd700; }
#scoreDisplay .value { color: #69db7c; }

#mobileControls {
    position: absolute;
    bottom: 15px;
    left: 0;
    right: 0;
    display: none;
    justify-content: space-between;
    padding: 0 15px;
    pointer-events: none;
    z-index: 20;
}

.mobile-btn {
    pointer-events: auto;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    border: 2px solid rgba(255,255,255,0.4);
    color: white;
    font-size: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    touch-action: none;
    transition: transform 0.1s;
}

.mobile-btn:active {
    transform: scale(0.85);
    background: rgba(255,255,255,0.4);
}

.mobile-btn.jump-btn {
    width: 80px;
    height: 80px;
    font-size: 32px;
    background: rgba(255, 215, 0, 0.3);
    border-color: #ffd700;
}

.mobile-btn.attack-btn {
    width: 70px;
    height: 70px;
    background: rgba(255, 50, 50, 0.3);
    border-color: #ff4444;
}

#menuOverlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-radius: 8px;
    z-index: 30;
    transition: opacity 0.5s;
}

#menuOverlay.hidden {
    opacity: 0;
    pointer-events: none;
}

.menu-title {
    font-size: 72px;
    font-weight: 900;
    color: #ffd700;
    text-shadow: 4px 4px 0 #7a4a12, 8px 8px 0 rgba(0,0,0,0.5);
    margin-bottom: 5px;
    animation: titleFloat 2s ease-in-out infinite;
}

@keyframes titleFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-12px) scale(1.02); }
}

.menu-subtitle {
    font-size: 22px;
    color: #a8d8ff;
    margin-bottom: 20px;
    letter-spacing: 2px;
}

.menu-info {
    background: rgba(255,255,255,0.08);
    padding: 20px 40px;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 25px;
    text-align: center;
    color: #d0e0ff;
    line-height: 1.8;
}

.menu-info kbd {
    background: rgba(255,255,255,0.15);
    padding: 2px 14px;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.2);
    color: #ffd700;
    font-weight: bold;
    font-size: 14px;
}

.btn {
    font-size: 28px;
    font-weight: bold;
    color: #fff;
    background: linear-gradient(135deg, #e8302a, #cc2222);
    border: none;
    border-radius: 16px;
    padding: 16px 50px;
    cursor: pointer;
    box-shadow: 0 8px 0 #7a1a17, 0 8px 40px rgba(232,48,42,0.4);
    transition: all 0.15s ease;
    letter-spacing: 2px;
    font-family: inherit;
}

.btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 0 #7a1a17, 0 12px 50px rgba(232,48,42,0.6);
}

.btn:active {
    transform: translateY(6px);
    box-shadow: 0 2px 0 #7a1a17;
}

.btn-green {
    background: linear-gradient(135deg, #2ecc40, #27ae60);
    box-shadow: 0 8px 0 #1a6b30, 0 8px 40px rgba(46, 204, 64, 0.4);
}

.btn-green:hover {
    box-shadow: 0 10px 0 #1a6b30, 0 12px 50px rgba(46, 204, 64, 0.6);
}

.btn-green:active {
    box-shadow: 0 2px 0 #1a6b30;
}

#gameOverMenu .menu-title { font-size: 56px; }
#gameOverMenu .menu-title.win { color: #2ecc40; }
#gameOverMenu .menu-title.lose { color: #ff4444; }

.stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 30px;
    margin: 10px 0 20px 0;
    color: #e0e8ff;
    font-size: 18px;
}

.stats-grid .stat-value {
    color: #ffd700;
    font-weight: bold;
}

@media (max-width: 860px) {
    #gameWrapper { transform: scale(0.85); }
    .menu-title { font-size: 48px; }
    #mobileControls { display: flex; }
}

@media (max-width: 600px) {
    #gameWrapper { transform: scale(0.6); }
    .menu-title { font-size: 36px; }
    .menu-info { padding: 12px 20px; font-size: 14px; }
    .btn { font-size: 20px; padding: 12px 30px; }
}

@media (pointer: coarse) {
    #mobileControls { display: flex; }
}
</style>
</head>
<body>

<div id="gameWrapper">
    <canvas id="gameCanvas" width="800" height="600"></canvas>

    <!-- HUD -->
    <div id="hud">
        <div class="hud-item" id="livesDisplay">
            <span class="icon">❤️</span>
            <span class="value" id="livesCount">3</span>
        </div>
        <div class="hud-item" id="coinsDisplay">
            <span class="icon">🪙</span>
            <span class="value" id="coinsCount">0</span>
        </div>
        <div class="hud-item" id="scoreDisplay">
            <span class="icon">⭐</span>
            <span class="value" id="scoreCount">0</span>
        </div>
        <div class="hud-item">
            <span class="icon">🏁</span>
            <span class="value" id="levelDisplay">1/3</span>
        </div>
    </div>

    <!-- Mobile Controls -->
    <div id="mobileControls">
        <div style="display:flex; gap:10px;">
            <button class="mobile-btn" id="btnLeft">◀</button>
            <button class="mobile-btn" id="btnRight">▶</button>
        </div>
        <div style="display:flex; gap:10px;">
            <button class="mobile-btn attack-btn" id="btnAttack">⚔️</button>
            <button class="mobile-btn jump-btn" id="btnJump">⬆</button>
        </div>
    </div>

    <!-- Menu -->
    <div id="menuOverlay">
        <div class="menu-title">🍄 سوبر رزوقه</div>
        <div class="menu-subtitle">⚡ المغامرة الكاملة ⚡</div>
        <div class="menu-info">
            <kbd>←</kbd> <kbd>→</kbd> للحركة &nbsp;|&nbsp; <kbd>Space</kbd> للقفز &nbsp;|&nbsp; <kbd>X</kbd> للضربة<br>
            🎯 اجمع العملات &nbsp;|&nbsp; 💀 احذر الأعداء &nbsp;|&nbsp; 🏁 أصل للنهاية
        </div>
        <button class="btn" id="startBtn">▶ ابدأ اللعبة</button>
    </div>

    <!-- Game Over Menu (hidden initially) -->
    <div id="gameOverMenu" style="display:none; position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); backdrop-filter:blur(8px); display:none; flex-direction:column; justify-content:center; align-items:center; border-radius:8px; z-index:35;">
        <div class="menu-title" id="resultTitle">🎉</div>
        <div class="menu-subtitle" id="resultSubtitle"></div>
        <div class="stats-grid" id="resultStats">
            <span>🏆 النقاط</span>
            <span class="stat-value" id="finalScore">0</span>
            <span>🪙 العملات</span>
            <span class="stat-value" id="finalCoins">0</span>
            <span>⏱️ الوقت</span>
            <span class="stat-value" id="finalTime">0</span>
            <span>📊 المستوى</span>
            <span class="stat-value" id="finalLevel">1</span>
        </div>
        <button class="btn" id="restartBtn">🔄 العب مجدداً</button>
    </div>
</div>

<script>
// ============================================================
//                     GAME CONFIG
// ============================================================
const CONFIG = {
    GRAVITY: 0.65,
    JUMP_FORCE: -14,
    MOVE_SPEED: 5,
    FRICTION: 0.85,
    MAX_LIVES: 5,
};

// ============================================================
//                     AUDIO ENGINE
// ============================================================
class SoundEngine {
    constructor() {
        this.ctx = null;
        this.enabled = true;
        this.sounds = {};
        this.init();
    }

    init() {
        try {
            this.ctx = new (window.AudioContext || window.webkitAudioContext)();
        } catch(e) {
            this.enabled = false;
        }
    }

    play(type) {
        if (!this.enabled || !this.ctx) return;
        try {
            const osc = this.ctx.createOscillator();
            const gain = this.ctx.createGain();
            osc.connect(gain);
            gain.connect(this.ctx.destination);

            const now = this.ctx.currentTime;
            switch(type) {
                case 'jump':
                    osc.frequency.setValueAtTime(300, now);
                    osc.frequency.exponentialRampToValueAtTime(600, now + 0.1);
                    gain.gain.setValueAtTime(0.15, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.1);
                    osc.start(now);
                    osc.stop(now + 0.1);
                    break;
                case 'coin':
                    osc.frequency.setValueAtTime(800, now);
                    osc.frequency.exponentialRampToValueAtTime(1200, now + 0.08);
                    gain.gain.setValueAtTime(0.12, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.1);
                    osc.start(now);
                    osc.stop(now + 0.1);
                    break;
                case 'stomp':
                    osc.frequency.setValueAtTime(200, now);
                    osc.frequency.exponentialRampToValueAtTime(80, now + 0.1);
                    gain.gain.setValueAtTime(0.15, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.1);
                    osc.start(now);
                    osc.stop(now + 0.1);
                    break;
                case 'die':
                    osc.frequency.setValueAtTime(500, now);
                    osc.frequency.exponentialRampToValueAtTime(100, now + 0.3);
                    gain.gain.setValueAtTime(0.15, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.3);
                    osc.start(now);
                    osc.stop(now + 0.3);
                    break;
                case 'win':
                    [523, 659, 784, 1047].forEach((freq, i) => {
                        const o = this.ctx.createOscillator();
                        const g = this.ctx.createGain();
                        o.connect(g);
                        g.connect(this.ctx.destination);
                        o.frequency.value = freq;
                        g.gain.setValueAtTime(0.1, now + i * 0.12);
                        g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.12 + 0.15);
                        o.start(now + i * 0.12);
                        o.stop(now + i * 0.12 + 0.15);
                    });
                    break;
                case 'bump':
                    osc.frequency.setValueAtTime(150, now);
                    osc.frequency.exponentialRampToValueAtTime(300, now + 0.05);
                    gain.gain.setValueAtTime(0.1, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.06);
                    osc.start(now);
                    osc.stop(now + 0.06);
                    break;
                default:
                    osc.frequency.setValueAtTime(400, now);
                    gain.gain.setValueAtTime(0.05, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.05);
                    osc.start(now);
                    osc.stop(now + 0.05);
            }
        } catch(e) {}
    }
}

const sound = new SoundEngine();

// ============================================================
//                     LEVEL DESIGN
// ============================================================
// Legend:
// P = Player start
// B = Brick platform
// C = Coin block (?) - gives coin and grows player
// M = Mushroom platform (special)
// E = End flag
// W = Walking enemy (Goomba)
// F = Flying enemy (Koopa)
// S = Spiked enemy (stationary hazard)
// K = King/Boss enemy
// G = Ground (solid)
// space = empty
// ~ = moving platform (horizontal)
// % = moving platform (vertical)

const LEVELS = [
    // Level 1 - Easy
    [
        "                                    ",
        "                                    ",
        "                                    ",
        "         C                          ",
        "                    C               ",
        "        W            W              ",
        "         B           B              ",
        "    P      B  C  B        W         ",
        "         GGGG  GGGG       GGGG      ",
        "   GGGGGG        GGGGGGGG    GGGGGG ",
        "GGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGG"
    ],
    // Level 2 - Medium
    [
        "                                    ",
        "                                    ",
        "          C           C             ",
        "                 C                  ",
        "    W                 W             ",
        "      B      F      B     W         ",
        "   P    B        B        B         ",
        "       GGGG    GGGG    GGGG         ",
        "  GGGG        GGGG        GGGG      ",
        "      GGGGGG        GGGGGG          ",
        "GGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGG"
    ],
    // Level 3 - Hard (with Boss)
    [
        "                                    ",
        "                                    ",
        "   C          C          C          ",
        "                                    ",
        "  W     F         F     W      S    ",
        "   B    B    C    B    B   S        ",
        "  P         B         B             ",
        "      GGGG     GGGG     GGGG        ",
        "  GGGG        GGGG        GGGG      ",
        "                          K         ",
        "GGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGG"
    ]
];

// ============================================================
//                     GAME STATE
// ============================================================
let canvas, ctx;
let player;
let platforms = [];
let enemies = [];
let bullets = [];
let particles = [];
let floatingTexts = [];
let coins = 0;
let score = 0;
let lives = 3;
let currentLevel = 0;
let cameraX = 0;
let gameRunning = false;
let gamePaused = false;
let frameCount = 0;
let startTime = 0;
let elapsedTime = 0;
let animFrameId = null;
let keys = {};

// ============================================================
//                     PARTICLE SYSTEM
// ============================================================
class Particle {
    constructor(x, y, color, vx, vy, life, size) {
        this.x = x;
        this.y = y;
        this.color = color;
        this.vx = vx || (Math.random() - 0.5) * 8;
        this.vy = vy || (Math.random() - 0.5) * 8 - 2;
        this.life = life || 40 + Math.random() * 30;
        this.maxLife = this.life;
        this.size = size || 4 + Math.random() * 6;
        this.gravity = 0.1;
        this.friction = 0.99;
    }

    update() {
        this.vx *= this.friction;
        this.vy *= this.friction;
        this.vy += this.gravity;
        this.x += this.vx;
        this.y += this.vy;
        this.life--;
        return this.life > 0;
    }

    draw(ctx, camX) {
        const alpha = this.life / this.maxLife;
        const size = this.size * (0.3 + 0.7 * alpha);
        ctx.globalAlpha = alpha;
        ctx.fillStyle = this.color;
        ctx.beginPath();
        ctx.arc(this.x - camX, this.y, size, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
    }
}

class FloatingText {
    constructor(x, y, text, color, size) {
        this.x = x;
        this.y = y;
        this.text = text;
        this.color = color || '#ffd700';
        this.size = size || 24;
        this.life = 50;
        this.maxLife = 50;
        this.vy = -2;
    }

    update() {
        this.y += this.vy;
        this.vy *= 0.97;
        this.life--;
        return this.life > 0;
    }

    draw(ctx, camX) {
        const alpha = this.life / this.maxLife;
        ctx.globalAlpha = alpha;
        ctx.fillStyle = this.color;
        ctx.font = `bold ${this.size}px Arial`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.shadowColor = 'rgba(0,0,0,0.8)';
        ctx.shadowBlur = 8;
        ctx.fillText(this.text, this.x - camX, this.y);
        ctx.shadowBlur = 0;
        ctx.globalAlpha = 1;
    }
}

// ============================================================
//                     PLAYER CLASS
// ============================================================
class Player {
    constructor(x, y) {
        this.x = x;
        this.y = y;
        this.width = 40;
        this.height = 52;
        this.velX = 0;
        this.velY = 0;
        this.onGround = false;
        this.facing = 1;
        this.walkCycle = 0;
        this.isAttacking = false;
        this.attackTimer = 0;
        this.attackCooldown = 0;
        this.invincible = 0;
        this.animState = 'idle';
        this.eyeBlink = 0;
    }

    update(platforms) {
        // Physics
        this.velY += CONFIG.GRAVITY;
        if (this.velY > 15) this.velY = 15;

        // Friction
        if (Math.abs(this.velX) > 0.1) {
            this.velX *= 0.88;
        } else {
            this.velX = 0;
        }

        // Move X
        this.x += this.velX;
        this.collideX(platforms);

        // Move Y
        this.y += this.velY;
        this.onGround = false;
        this.collideY(platforms);

        // Animation
        if (this.onGround) {
            if (Math.abs(this.velX) > 0.5) {
                this.animState = 'walk';
                this.walkCycle += 0.15;
            } else {
                this.animState = 'idle';
            }
        } else {
            this.animState = this.velY < 0 ? 'jump' : 'fall';
        }

        // Attack
        if (this.attackCooldown > 0) this.attackCooldown--;
        if (this.isAttacking) {
            this.attackTimer--;
            if (this.attackTimer <= 0) {
                this.isAttacking = false;
            }
        }

        // Invincibility
        if (this.invincible > 0) this.invincible--;

        // Eye blink
        this.eyeBlink = (this.eyeBlink + 1) % 200;

        // Boundaries
        if (this.x < 0) this.x = 0;
        if (this.y > 650) {
            this.die();
        }
    }

    collideX(platforms) {
        for (let p of platforms) {
            if (this.x < p.x + p.width && this.x + this.width > p.x &&
                this.y < p.y + p.height && this.y + this.height > p.y) {
                if (this.velX > 0) {
                    this.x = p.x - this.width;
                } else if (this.velX < 0) {
                    this.x = p.x + p.width;
                }
                this.velX = 0;
            }
        }
    }

    collideY(platforms) {
        for (let p of platforms) {
            if (this.x < p.x + p.width && this.x + this.width > p.x &&
                this.y < p.y + p.height && this.y + this.height > p.y) {
                if (this.velY > 0) {
                    this.y = p.y - this.height;
                    this.onGround = true;
                    this.velY = 0;
                    // Check coin block
                    if (p.type === 'C' && !p.used) {
                        p.used = true;
                        coins++;
                        score += 50;
                        sound.play('coin');
                        spawnParticles(p.x + p.width/2, p.y, '#ffd700', 20);
                        addFloatingText(p.x + p.width/2, p.y - 20, '+🪙', '#ffd700');
                        // Grow player
                        if (this.width < 50) {
                            this.width *= 1.15;
                            this.height *= 1.15;
                        }
                    }
                } else if (this.velY < 0) {
                    this.y = p.y + p.height;
                    this.velY = 0;
                    // Bump head
                    if (p.type === 'B' || p.type === 'C') {
                        sound.play('bump');
                    }
                }
            }
        }
    }

    jump() {
        if (this.onGround) {
            this.velY = CONFIG.JUMP_FORCE;
            this.onGround = false;
            sound.play('jump');
            spawnParticles(this.x + this.width/2, this.y + this.height, '#aaddff', 6);
        }
    }

    attack() {
        if (this.attackCooldown > 0 || this.isAttacking) return;
        this.isAttacking = true;
        this.attackTimer = 18;
        this.attackCooldown = 20;
        sound.play('stomp');
        // Attack hitbox check
        const ax = this.x + (this.facing > 0 ? this.width : -30);
        const ay = this.y - 10;
        const aw = 40;
        const ah = this.height + 20;
        for (let en of enemies) {
            if (!en.alive) continue;
            if (ax < en.x + en.width && ax + aw > en.x &&
                ay < en.y + en.height && ay + ah > en.y) {
                en.hit();
                score += 100;
                addFloatingText(en.x + en.width/2, en.y - 20, '+💥', '#ff6b6b');
            }
        }
        spawnParticles(this.x + this.width/2 + this.facing * 30, this.y + this.height/2, '#ff6b6b', 10);
    }

    die() {
        if (this.invincible > 0) return;
        lives--;
        sound.play('die');
        spawnParticles(this.x + this.width/2, this.y + this.height/2, '#ff4444', 30);
        if (lives <= 0) {
            gameOver(false);
        } else {
            this.invincible = 120;
            // Respawn at level start
            const start = findPlayerStart(currentLevel);
            if (start) {
                this.x = start.x;
                this.y = start.y;
                this.velX = 0;
                this.velY = 0;
            }
        }
        updateHUD();
    }

    draw(ctx, camX) {
        const dx = this.x - camX;
        const dy = this.y;

        // Shadow
