<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super Mario HTML5 Clone</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: #222;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            font-family: Arial, sans-serif;
        }
        canvas {
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }
        #info {
            position: absolute;
            top: 10px;
            color: white;
            font-size: 18px;
            background: rgba(0,0,0,0.5);
            padding: 5px 15px;
            border-radius: 5px;
        }
        #startMenu {
            position: absolute;
            width: 800px;
            height: 600px;
            border-radius: 0;
            overflow: hidden;
            z-index: 10;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }
        #menuBackground {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 30% 30%, #5c94fc, #1a3b7a);
            overflow: hidden;
        }
        .stars { position: absolute; width: 100%; height: 100%; }
        .star {
            position: absolute;
            background: white;
            border-radius: 50%;
            animation: twinkle 2s ease-in-out infinite alternate;
        }
        @keyframes twinkle {
            0% { opacity: 0.2; transform: scale(0.8); }
            100% { opacity: 1; transform: scale(1.2); }
        }
        .cloud {
            position: absolute;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 100px;
            animation: floatCloud 20s linear infinite;
        }
        @keyframes floatCloud {
            0% { transform: translateX(-200px); }
            100% { transform: translateX(1100px); }
        }
        #menuContent {
            position: relative;
            z-index: 10;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 30px;
            text-align: center;
            color: white;
        }
        .game-title {
            font-size: 64px;
            font-weight: 900;
            color: #ffcc00;
            text-shadow: 4px 4px 0 #7a4a12, 8px 8px 0 rgba(0,0,0,0.3), 0 0 40px rgba(255,204,0,0.3);
            letter-spacing: 4px;
            margin-bottom: 5px;
            animation: titleBounce 3s ease-in-out infinite;
        }
        @keyframes titleBounce {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-10px) scale(1.02); }
        }
        .title-icon {
            font-size: 50px;
            display: inline-block;
            animation: spinIcon 8s linear infinite;
        }
        @keyframes spinIcon {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .subtitle {
            font-size: 22px;
            background: rgba(0,0,0,0.35);
            padding: 8px 32px;
            border-radius: 50px;
            margin: 8px 0 16px 0;
            border: 2px solid rgba(255,255,255,0.15);
            letter-spacing: 2px;
            font-weight: 300;
        }
        .subtitle span { color: #ffd700; font-weight: bold; }
        .controls-box {
            background: rgba(0,0,0,0.4);
            padding: 14px 28px;
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.1);
            margin: 8px 0 24px 0;
            max-width: 550px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        .controls-box p { font-size: 15px; color: #d0e0ff; line-height: 2; margin: 0; }
        .controls-box kbd {
            background: rgba(255,255,255,0.15);
            padding: 3px 14px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.2);
            font-family: inherit;
            color: #ffd700;
            font-weight: bold;
            font-size: 13px;
        }
        .controls-box .warning { color: #ffb3b3; font-size: 13px; }
        .controls-box .warning kbd { color: #ff6b6b; border-color: #ff6b6b; }
        #startButton {
            font-family: inherit;
            font-size: 26px;
            font-weight: bold;
            color: #fff;
            background: linear-gradient(135deg, #e8302a, #cc2222);
            border: none;
            border-radius: 20px;
            padding: 16px 50px;
            cursor: pointer;
            box-shadow: 0 8px 0 #7a1a17, 0 8px 30px rgba(232,48,42,0.4);
            transition: all 0.15s ease;
            letter-spacing: 2px;
            animation: pulseGlow 2s ease-in-out infinite;
        }
        @keyframes pulseGlow {
            0%, 100% { box-shadow: 0 8px 0 #7a1a17, 0 8px 30px rgba(232,48,42,0.4); }
            50% { box-shadow: 0 8px 0 #7a1a17, 0 8px 50px rgba(232,48,42,0.8); }
        }
        #startButton:hover { transform: translateY(-3px) scale(1.03); }
        #startButton:active { transform: translateY(6px); box-shadow: 0 2px 0 #7a1a17; }
        .mushroom-deco {
            position: absolute;
            font-size: 45px;
            opacity: 0.3;
            animation: floatMushroom 4s ease-in-out infinite;
        }
        @keyframes floatMushroom {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(5deg); }
        }
        .mushroom-deco:nth-child(1) { bottom: 20px; left: 30px; animation-delay: 0s; }
        .mushroom-deco:nth-child(2) { bottom: 20px; right: 30px; animation-delay: 1s; }
        .mushroom-deco:nth-child(3) { top: 20px; left: 30px; animation-delay: 2s; font-size: 32px; }
        .mushroom-deco:nth-child(4) { top: 20px; right: 30px; animation-delay: 3s; font-size: 32px; }
        .wave {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 200%;
            height: 60px;
            background: rgba(255,255,255,0.05);
            border-radius: 100% 100% 0 0 / 30% 30% 0 0;
            animation: waveMove 8s linear infinite;
        }
        .wave:nth-child(2) {
            bottom: -10px;
            opacity: 0.5;
            animation-duration: 6s;
            animation-delay: -2s;
            height: 40px;
        }
        @keyframes waveMove {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
    </style>
</head>
<body>

<div id="info">المرحلة: <span id="level-num">1</span> | الأسهم للحركة والقفز | X للضربة</div>
<canvas id="gameCanvas" width="800" height="600"></canvas>

<div id="startMenu">
    <div id="menuBackground">
        <div class="stars" id="starsContainer"></div>
        <div class="cloud" style="top: 10%; width: 160px; height: 40px; animation-duration: 25s;"></div>
        <div class="cloud" style="top: 25%; width: 120px; height: 32px; animation-duration: 30s; animation-delay: -8s;"></div>
        <div class="cloud" style="top: 5%; width: 140px; height: 36px; animation-duration: 22s; animation-delay: -15s;"></div>
        <div class="wave"></div>
        <div class="wave"></div>
        <div class="mushroom-deco">🍄</div>
        <div class="mushroom-deco">🍄</div>
        <div class="mushroom-deco">⭐</div>
        <div class="mushroom-deco">⭐</div>
    </div>
    <div id="menuContent">
        <h1 class="game-title"><span class="title-icon">🍄</span> سوبر رزوقه</h1>
        <div class="subtitle">⚡ <span>المغامرة</span> تبدأ الآن ⚡</div>
        <div class="controls-box">
            <p>
                <kbd>←</kbd> <kbd>→</kbd> أو <kbd>A</kbd> <kbd>D</kbd> للحركة &nbsp;|&nbsp;
                <kbd>Space</kbd> أو <kbd>↑</kbd> للقفز &nbsp;|&nbsp;
                <kbd>X</kbd> للضربة
            </p>
            <p class="warning">⚠️ اقفز على الأعداء أو اضربهم بـ <kbd>X</kbd> — احذر الشوكي والبوس في النهاية!</p>
        </div>
        <button id="startButton">▶ ابدأ اللعبة</button>
    </div>
</div>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

function createMenuStars() {
    const container = document.getElementById('starsContainer');
    const numStars = 60;
    for (let i = 0; i < numStars; i++) {
        const star = document.createElement('div');
        star.className = 'star';
        const size = Math.random() * 4 + 2;
        star.style.width = size + 'px';
        star.style.height = size + 'px';
        star.style.left = Math.random() * 100 + '%';
        star.style.top = Math.random() * 70 + '%';
        star.style.animationDelay = Math.random() * 3 + 's';
        star.style.animationDuration = (Math.random() * 2 + 1.5) + 's';
        container.appendChild(star);
    }
}
createMenuStars();

const subtitleSpan = document.querySelector('.subtitle span');
const subtitleColors = ['#ffd700', '#ff6b6b', '#4ecdc4', '#45b7d1', '#ffa502'];
setInterval(() => {
    subtitleSpan.style.color = subtitleColors[Math.floor(Math.random() * subtitleColors.length)];
}, 2000);
ctx.imageSmoothingEnabled = true;
ctx.imageSmoothingQuality = "high";

const playerImage = new Image();
playerImage.src = 'https://raw.githubusercontent.com/eliasaj5312/uper-Razzouqa/main/f6ad2363-1161-4b8e-b8ad-b7de753e6635.png';

const attackImage = new Image();
attackImage.src = 'data:image/png;base64,';

let currentLevelIdx = 0;
let cameraX = 0;

const skyImage = new Image();
skyImage.src = 'data:image/png;base64,';

const botFaceImage = new Image();
botFaceImage.src = 'data:image/png;base64,';

const bossBulletImage = new Image();
bossBulletImage.src = 'data:image/png;base64,';

const LEVELS = [
    [
        "                                                                ",
        "                                                                ",
        "                         F                                      ",
        "                                                                ",
        "                                                                ",
        "         C   C                                                  ",
        "                                                                ",
        "     M             M                                           E",
        "P       W   S        W                                 K        ",
        "BBBBBBBBB   BBBBBBBBBBBBBBBB   BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB"
    ]
];

class Player {
    constructor(x, y) {
        this.x = x;
        this.y = y;
        this.width = 100;
        this.height = 112;
        this.velX = 0;
        this.velY = 0;
        this.jumpPower = -18;
        this.gravity = 0.6;
        this.onGround = false;
        this.isAttacking = false;
        this.attackTimer = 0;
        this.walkCycle = 0;
        this.facing = 1;
    }

    update(platforms) {
        this.velY += this.gravity;

        this.x += this.velX;
        this.collide(platforms, 'x');

        this.y += this.velY;
        this.onGround = false;
        this.collide(platforms, 'y');

        // تحديث دورة رسوم المشي
        if (this.velX !== 0) {
            this.facing = this.velX > 0 ? 1 : -1;
        }
        if (this.onGround && this.velX !== 0) {
            this.walkCycle += 0.35;
        } else if (this.onGround) {
            this.walkCycle *= 0.7; // رجوع تدريجي للوقوف
        }
    }

    collide(platforms, direction) {
        for (let p of platforms) {
            if (this.x < p.x + p.width && this.x + this.width > p.x &&
                this.y < p.y + p.height && this.y + this.height > p.y) {

                if (direction === 'x') {
                    if (this.velX > 0) this.x = p.x - this.width;
                    if (this.velX < 0) this.x = p.x + p.width;
                } else if (direction === 'y') {
                    if (this.velY > 0) {
                        this.y = p.y - this.height;
                        this.velY = 0;
                        this.onGround = true;
                    }
                    if (this.velY < 0) {
                        this.y = p.y + p.height;
                        this.velY = 0;
                        if (p.type === 'C' && !p.used) {
                            p.used = true;
                            this.width *= 1.08;
                            this.height *= 1.08;
                        }
                    }
                }
            }
        }
    }

    jump() {
        if (this.onGround) {
            this.velY = this.jumpPower;
        }
    }

    attack() {
        this.isAttacking = true;
        this.attackTimer = 20; // مدة الضربة (بالإطارات) قبل الرجوع للشكل الأصلي
    }

    updateAttack() {
        if (this.isAttacking) {
            this.attackTimer--;
            if (this.attackTimer <= 0) {
                this.isAttacking = false;
            }
        }
    }
}

// رسم الخلفية: سماء متدرجة + غيوم + تلال (مع تأثير عمق بسيط)
function drawBackground() {
    // السماء المصورة (بيكسل آرت) بتكرار أفقي مع تأثير عمق بسيط
    if (skyImage.complete && skyImage.naturalWidth !== 0) {
        const skyOffset = (cameraX * 0.2) % canvas.width;
        for (let i = -1; i < 3; i++) {
            ctx.drawImage(skyImage, i * canvas.width - skyOffset, 0, canvas.width, canvas.height);
        }
    } else {
        const g = ctx.createLinearGradient(0, 0, 0, canvas.height);
        g.addColorStop(0, "#2f6fdb");
        g.addColorStop(1, "#8fbcff");
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
    }
}

function drawShadow(x, y, width, height) {
    ctx.save();
    ctx.fillStyle = "rgba(0,0,0,0.28)";
    ctx.beginPath();
    ctx.ellipse(x + width / 2, y + height - 4, width * 0.42, 7, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
}

function drawCloud(x, y) {
    ctx.beginPath();
    ctx.arc(x, y, 20, 0, Math.PI * 2);
    ctx.arc(x + 22, y - 10, 24, 0, Math.PI * 2);
    ctx.arc(x + 46, y, 20, 0, Math.PI * 2);
    ctx.arc(x + 22, y + 8, 22, 0, Math.PI * 2);
    ctx.fill();
}

class Platform {
    constructor(x, y, w, h, type, moving = false, axis = 'y', range = 80, speed = 0.03) {
        this.x = x;
        this.y = y;
        this.width = w;
        this.height = h;
        this.type = type;
        this.moving = moving;
        this.axis = axis;
        this.range = range;
        this.moveSpeed = speed;
        this.baseX = x;
        this.baseY = y;
        this.angle = Math.random() * Math.PI * 2;
        this.used = false;
    }

    update() {
        if (!this.moving) return;
        this.angle += this.moveSpeed;
        if (this.axis === 'y') {
            this.y = this.baseY + Math.sin(this.angle) * this.range;
        } else {
            this.x = this.baseX + Math.sin(this.angle) * this.range;
        }
    }

    draw() {
        const dx = this.x - cameraX;

        if (this.type === 'B') {
            // جسم التربة الطوبي
            ctx.fillStyle = "#c77b3f";
            ctx.fillRect(dx, this.y, this.width, this.height);

            // خطوط الطوب (مورتار داكن)
            ctx.strokeStyle = "rgba(90,50,20,0.6)";
            ctx.lineWidth = 2;
            const brickH = 15;
            for (let by = this.y; by < this.y + this.height; by += brickH) {
                ctx.beginPath();
                ctx.moveTo(dx, by);
                ctx.lineTo(dx + this.width, by);
                ctx.stroke();
                const offset = (Math.floor((by - this.y) / brickH) % 2 === 0) ? 0 : this.width / 2;
                for (let bx = offset; bx < this.width; bx += this.width / 2) {
                    ctx.beginPath();
                    ctx.moveTo(dx + bx, by);
                    ctx.lineTo(dx + bx, Math.min(by + brickH, this.y + this.height));
                    ctx.stroke();
                }
            }

            // طبقة العشب فوق التربة
            const grassHeight = 14;
            ctx.fillStyle = "#4CAF50";
            ctx.fillRect(dx, this.y, this.width, grassHeight);
            ctx.fillStyle = "#66d16a";
            ctx.fillRect(dx, this.y, this.width, 5);

            // حبيبات عشب مقوسة على الحافة العلوية (نمط ماريو الكلاسيكي)
            ctx.fillStyle = "#4CAF50";
            for (let i = 0; i < this.width; i += 12) {
                ctx.beginPath();
                ctx.arc(dx + i + 6, this.y, 6, Math.PI, 0);
                ctx.fill();
            }
            return;
        }
        else if (this.type === 'C') {
            // صندوق المفاجآت الكلاسيكي
            ctx.fillStyle = this.used ? "#8a7860" : "#e8a33d";
            ctx.fillRect(dx, this.y, this.width, this.height);

            ctx.strokeStyle = "#7a4a12";
            ctx.lineWidth = 3;
            ctx.strokeRect(dx + 2, this.y + 2, this.width - 4, this.height - 4);

            // برادي الزوايا
            ctx.fillStyle = "#7a4a12";
            const r = 5;
            ctx.fillRect(dx + 3, this.y + 3, r, r);
            ctx.fillRect(dx + this.width - r - 3, this.y + 3, r, r);
            ctx.fillRect(dx + 3, this.y + this.height - r - 3, r, r);
            ctx.fillRect(dx + this.width - r - 3, this.y + this.height - r - 3, r, r);

            if (!this.used) {
                // علامة الاستفهام
                ctx.fillStyle = "#fff9e6";
                ctx.font = "bold 30px Arial";
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                ctx.fillText("?", dx + this.width / 2, this.y + this.height / 2 + 2);
            }
            return;
        }
        else if (this.type === 'E') {
            // عمود العلم
            const poleX = dx + this.width / 2;
            ctx.strokeStyle = "#c9c9c9";
            ctx.lineWidth = 4;
            ctx.beginPath();
            ctx.moveTo(poleX, this.y);
            ctx.lineTo(poleX, this.y + this.height);
            ctx.stroke();

            // كرة أعلى العمود
            ctx.fillStyle = "#ffd700";
            ctx.beginPath();
            ctx.arc(poleX, this.y, 7, 0, Math.PI * 2);
            ctx.fill();

            // العلم
            ctx.fillStyle = "#2ecc40";
            ctx.beginPath();
            ctx.moveTo(poleX, this.y + 12);
            ctx.lineTo(poleX + 32, this.y + 22);
            ctx.lineTo(poleX, this.y + 32);
            ctx.closePath();
            ctx.fill();
            return;
        }

        ctx.fillRect(dx, this.y, this.width, this.height);
    }
}

let player;
let platforms = [];
let enemies = [];
let bullets = [];
let endGate = null;

class Enemy {
    constructor(x, y, type) {
        this.x = x;
        this.y = y;
        this.type = type; // 'W' = ماشي, 'S' = شوكي ثابت, 'F' = طائر, 'K' = بوس
        if (type === 'K') {
            this.width = 90;
            this.height = 120;
            this.y = y - (this.height - 40); // يقف على نفس مستوى الأرض رغم كبر حجمه
            this.shootTimer = 160;
        } else {
            this.width = 40;
            this.height = 40;
        }
        this.alive = true;
        this.dir = 1;
        this.baseY = this.y;
        this.angle = Math.random() * Math.PI * 2;
        this.rangeCounter = 0;
        this.speed = this.type === 'W' ? 1.6 : (this.type === 'F' ? 1.8 : 1.0);
    }

    update(platforms) {
        if (!this.alive) return;

        if (this.type === 'W' || this.type === 'S') {
            this.x += this.speed * this.dir;

            // ينعكس عند اصطدامه بجدار
            for (let p of platforms) {
                if (p.type !== 'B') continue;
                if (this.x < p.x + p.width && this.x + this.width > p.x &&
                    this.y < p.y + p.height && this.y + this.height > p.y) {
                    this.x -= this.speed * this.dir;
                    this.dir *= -1;
                }
            }

            // ينعكس لو مفيش أرض قدامه (يمنع سقوطه من الحافة)
            let groundAhead = false;
            const checkX = this.dir > 0 ? this.x + this.width + 4 : this.x - 4;
            for (let p of platforms) {
                if (p.type !== 'B') continue;
                if (checkX >= p.x && checkX <= p.x + p.width &&
                    Math.abs((this.y + this.height) - p.y) < 12) {
                    groundAhead = true;
                }
            }
            if (!groundAhead) this.dir *= -1;

        } else if (this.type === 'F') {
            this.angle += 0.06;
            this.y = this.baseY + Math.sin(this.angle) * 25;
            this.x += this.speed * this.dir;
            this.rangeCounter++;
            if (this.rangeCounter > 100) {
                this.dir *= -1;
                this.rangeCounter = 0;
            }
        } else if (this.type === 'K') {
            this.angle += 0.03;
            this.y = this.baseY + Math.sin(this.angle) * 6;

            this.shootTimer--;
            if (this.shootTimer <= 0) {
                this.shootTimer = 180;
                bullets.push({
                    x: this.x,
                    y: this.y + this.height * 0.4,
                    vx: -4,
                    width: 16,
                    height: 10,
                    drawSize: 34,
                    alive: true
                });
            }
        }
    }

    draw() {
        if (!this.alive) return;
        const dx = this.x - cameraX;

        if (this.type === 'W') {
            // عدو ماشي - يستخدم صورة الشخصية المرفوعة
            if (attackImage.complete && attackImage.naturalWidth !== 0) {
                ctx.drawImage(attackImage, dx, this.y - 10, this.width, this.height + 10);
            } else {
                ctx.fillStyle = "#7a4a2a";
                ctx.fillRect(dx, this.y, this.width, this.height);
            }

        } else if (this.type === 'F') {
            // البوتات: تستخدم صورة الوجه المرفوعة
            const bob = Math.sin(this.angle * 4) * 4;
            if (botFaceImage.complete && botFaceImage.naturalWidth !== 0) {
                ctx.drawImage(botFaceImage, dx, this.y + bob, this.width, this.height);
            } else {
                ctx.fillStyle = "#8e44ad";
                ctx.beginPath();
                ctx.ellipse(dx + this.width / 2, this.y + this.height / 2, this.width / 2, this.height / 2.5, 0, 0, Math.PI * 2);
                ctx.fill();
            }

        } else if (this.type === 'S') {
            // عدو شوكي ثابت (خطر دائم حتى من فوق)
            ctx.fillStyle = "#c0392b";
            ctx.beginPath();
            ctx.arc(dx + this.width / 2, this.y + this.height / 2, this.width / 2 - 4, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = "#7b241c";
            const spikes = 8;
            for (let i = 0; i < spikes; i++) {
                const ang = (i / spikes) * Math.PI * 2;
                const cx = dx + this.width / 2 + Math.cos(ang) * (this.width / 2 - 4);
                const cy = this.y + this.height / 2 + Math.sin(ang) * (this.width / 2 - 4);
                const tx = dx + this.width / 2 + Math.cos(ang) * (this.width / 2 + 6);
                const ty = this.y + this.height / 2 + Math.sin(ang) * (this.width / 2 + 6);
                ctx.beginPath();
                ctx.moveTo(cx - 3, cy - 3);
                ctx.lineTo(tx, ty);
                ctx.lineTo(cx + 3, cy + 3);
                ctx.closePath();
                ctx.fill();
            }
        } else if (this.type === 'K') {
            // البوس الأخير: نفس شخصية الصورة المرفوعة، لكن بحجم كبير
            const bx = dx, by = this.y;
            if (attackImage.complete && attackImage.naturalWidth !== 0) {
                ctx.drawImage(attackImage, bx, by, this.width, this.height);
                // توهج أحمر خفيف حول البوس لإضفاء طابع مخيف
                const eyeGlow = 0.15 + Math.abs(Math.sin(this.angle * 3)) * 0.15;
                ctx.fillStyle = `rgba(255,0,0,${eyeGlow})`;
                ctx.fillRect(bx, by, this.width, this.height);
            } else {
                ctx.fillStyle = "#3a1f1f";
                ctx.fillRect(bx, by, this.width, this.height);
            }
        }
    }
}

function loadLevel(idx) {
    platforms = [];
    enemies = [];
    bullets = [];
    let movingCount = 0;
    document.getElementById("level-num").innerText = idx + 1;
    const levelData = LEVELS[idx];
    const tileSize = 60;

    for (let row = 0; row < levelData.length; row++) {
        for (let col = 0; col < levelData[row].length; col++) {
            let char = levelData[row][col];
            let x = col * tileSize;
            let y = row * tileSize;

            if (char === 'B' || char === 'C') {
                platforms.push(new Platform(x, y, tileSize, tileSize, char));
            } else if (char === 'M') {
                platforms.push(new Platform(x, y, tileSize, tileSize, 'B', false));
            } else if (char === 'E') {
                endGate = new Platform(x, y - tileSize, tileSize, tileSize * 2, 'E');
            } else if (char === 'P') {
                player = new Player(x, y);
            } else if (char === 'W' || char === 'S' || char === 'F' || char === 'K') {
                enemies.push(new Enemy(x, y, char));
            }
        }
    }
    cameraX = 0;
}

const keys = {};
window.addEventListener("keydown", e => {
    keys[e.code] = true;
    if (e.code === "Space" || e.code === "ArrowUp") player.jump();
    if (e.code === "KeyX") player.attack();
});
window.addEventListener("keyup", e => keys[e.code] = false);

function gameLoop() {
    player.velX = 0;
    if (keys["ArrowRight"] || keys["KeyD"]) player.velX = 4;
    if (keys["ArrowLeft"] || keys["KeyA"]) player.velX = -4;

    platforms.forEach(p => p.update());
    player.update(platforms);
    player.updateAttack();

    enemies.forEach(en => en.update(platforms));

    for (let en of enemies) {
        if (!en.alive) continue;
        const hit = player.x < en.x + en.width && player.x + player.width > en.x &&
                    player.y < en.y + en.height && player.y + player.height > en.y;
        if (!hit) continue;

        if (player.isAttacking) {
            // الضربة تقضي على أي عدو
            en.alive = false;
        } else if (en.type !== 'S' && en.type !== 'K' && player.velY > 0 && (player.y + player.height) - en.y < 20) {
            // القفز فوق العدو (عدا الشوكي والبوس) يقضي عليه
            en.alive = false;
            player.velY = -10;
        } else {
            // الاصطدام بعدو = إعادة تشغيل المرحلة
            loadLevel(currentLevelIdx);
        }
    }

    // تحديث الطلقات وتصادمها مع اللاعب
    for (let b of bullets) {
        if (!b.alive) continue;
        b.x += b.vx;
        if (b.x - cameraX < -60 || b.x - cameraX > canvas.width + 60) {
            b.alive = false;
            continue;
        }
        const bulletHit = player.x < b.x + b.width && player.x + player.width > b.x &&
                           player.y < b.y + b.height && player.y + player.height > b.y;
        if (bulletHit) {
            b.alive = false;
            loadLevel(currentLevelIdx);
        }
    }
    bullets = bullets.filter(b => b.alive);

    if (player.x - cameraX > canvas.width / 2) {
        cameraX = player.x - canvas.width / 2;
    }
    if (player.x - cameraX < canvas.width / 4 && cameraX > 0) {
        cameraX = player.x - canvas.width / 4;
    }

    if (endGate && player.x < endGate.x + endGate.width && player.x + player.width > endGate.x &&
        player.y < endGate.y + endGate.height && player.y + player.height > endGate.y) {
        alert("مبروك! لقد فزت بالمرحلة!");
        loadLevel(currentLevelIdx);
    }

    if (player.y > canvas.height) {
        loadLevel(currentLevelIdx);
    }

    drawBackground();

    platforms.forEach(p => p.draw());

    enemies.forEach(en => { if (en.alive) drawShadow(en.x - cameraX, en.y, en.width, en.height); });
    enemies.forEach(en => en.draw());

    bullets.forEach(b => {
        const bdx = b.x - cameraX;
        if (bossBulletImage.complete && bossBulletImage.naturalWidth !== 0) {
            ctx.save();
            const cx = bdx + b.width / 2, cy = b.y + b.height / 2;
            ctx.translate(cx, cy);
            if (b.vx > 0) ctx.scale(-1, 1); // الطلقة تصميمها متجه لليسار أصلاً
            ctx.drawImage(bossBulletImage, -b.drawSize / 2, -b.drawSize / 2, b.drawSize, b.drawSize);
            ctx.restore();
        } else {
            ctx.fillStyle = "#ff6a00";
            ctx.beginPath();
            ctx.ellipse(bdx + b.width / 2, b.y + b.height / 2, b.width / 2, b.height / 2, 0, 0, Math.PI * 2);
            ctx.fill();
        }
    });

    if (endGate) endGate.draw();

    drawShadow(player.x - cameraX, player.y, player.width, player.height);

    const activeImage = player.isAttacking ? attackImage : playerImage;

    // حساب تأثيرات الحركة (بديل عن فريمات حقيقية بما إننا نستخدم صورة واحدة)
    let bob = 0, squashX = 1, squashY = 1, tilt = 0;
    if (!player.onGround) {
        // تمدد لأعلى عند القفز، وانضغاط عند الهبوط السريع
        if (player.velY < -2) { squashY = 1.08; squashX = 0.94; }
        else if (player.velY > 6) { squashY = 0.9; squashX = 1.08; }
    } else if (Math.abs(player.velX) > 0.1) {
        // تمايل ورفرفة بسيطة تحاكي خطوات المشي
        bob = Math.abs(Math.sin(player.walkCycle)) * 5;
        tilt = Math.sin(player.walkCycle) * 0.05;
    }

    const cx = player.x - cameraX + player.width / 2;
    const cy = player.y + player.height / 2 - bob;

    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(tilt);
    ctx.scale(player.facing * squashX, squashY);
    if (activeImage.complete && activeImage.naturalWidth !== 0) {
        ctx.drawImage(activeImage, -player.width / 2, -player.height / 2, player.width, player.height);
    } else {
        ctx.fillStyle = "red";
        ctx.fillRect(-player.width / 2, -player.height / 2, player.width, player.height);
    }
    ctx.restore();

    requestAnimationFrame(gameLoop);
}

// تشغيل اللعبة عند الضغط على زر البدء
loadLevel(currentLevelIdx);
document.getElementById("startButton").addEventListener("click", () => {
    document.getElementById("startMenu").style.display = "none";
    gameLoop();
});
</script>

